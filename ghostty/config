# Ghostty Terminal Configuration
# Ref: https://ghostty.org/docs/config/reference

theme = slate
font-family = Berkeley Mono
window-title-font-family = Berkeley Mono
font-size = 12
font-feature = -calt

window-decoration = none
# window-decoration = client
macos-titlebar-style = tabs
macos-option-as-alt = left
window-save-state = always
adjust-cursor-thickness = 2

# mouse-hide-while-typing = true
# macos-non-native-fullscreen = visible-menu
# macos-titlebar-proxy-icon = hidden
# window-padding-balance=true

keybind = super+s>r=reload_config
keybind = super+s>x=close_surface
keybind = shift+enter=text:\x1b\r
keybind = global:ctrl+backquote=toggle_quick_terminal

keybind = cmd+s>\=new_split:right
keybind = cmd+s>-=new_split:down
keybind = cmd+s>j=goto_split:bottom
keybind = cmd+s>k=goto_split:top
keybind = cmd+s>h=goto_split:left
keybind = cmd+s>l=goto_split:right
keybind = super+\=goto_split:previous
keybind = cmd+s>z=toggle_split_zoom
keybind = cmd+s>e=equalize_splits
