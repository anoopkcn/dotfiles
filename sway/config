# Sway config — Wayland port of i3/config.
# Sway searches ~/.config/sway/config before falling back to ~/.config/i3/config,
# so this file is what keeps sway from loading the (X11-only) i3 config.
# Reference: man 5 sway

set $mod Mod4
set $left h
set $down j
set $up k
set $right l
set $term kitty

# Colors — slate (matches i3/config and nvim/colors/slate.lua)
set $bg        #14161d
set $bg_alt    #1d2029
set $fg        #e0e2ea
set $muted     #828c9e
set $accent    #88a0c8
set $accent2   #a0ddac
set $urgent    #f7768e
set $border    #32384a
set $sel       #3c4e7a
set $dim       #565f70

font pango:Berkeley Mono Variable 10

# Screen lock command (used by swayidle and the manual bind)
set $lock swaylock -f -c 14161d

### Output / display
# 14" 1920x1200 panel @ ~161 DPI. Native resolution, no scaling (scale 1.0):
# pixel-perfect everywhere (incl. XWayland) with the smallest UI/font sizes.
output eDP-1 mode 1920x1200@60Hz scale 1.0
output * bg ~/Images/wallpaper/fall-echo-tries.png fill

### Idle / lock (swayidle + swaylock replace xss-lock/slock/xidlehook)
# Lock after 10 min, power off displays after 15, and lock before sleep.
# Idle is suppressed while:
#   - a window is fullscreen (inhibit_idle fullscreen, below), and
#   - audio is playing — swayidle.sh checks pactl before locking, replacing
#     xidlehook's --not-when-audio so windowed videos (browser) don't lock.
exec_always ~/.config/sway/swayidle.sh
for_window [app_id=".*"] inhibit_idle fullscreen
for_window [class=".*"] inhibit_idle fullscreen

### Autostart
# NB: no `dex --autostart` here — it would pull in X11-only picom.desktop from
# /etc/xdg/autostart and double-launch the applets below. Start what we need explicitly.
exec nm-applet --indicator
exec blueman-applet
exec dunst
# polkit authentication agent — shows the GUI password prompt when an app
# (udisks mounts, NetworkManager, GUI installers) requests privilege escalation.
# Requires the polkit-gnome package. Harmless no-op if not installed.
exec /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec_always sh -c 'pkill -x waybar; exec waybar'
# cliphist watchers record clipboard history (text + images) for $mod+v
exec wl-paste --type text --watch cliphist store
exec wl-paste --type image --watch cliphist store

### Cursor — uniform pointer theme/size across Wayland + XWayland (see environment.d)
seat seat0 xcursor_theme Adwaita 24

### Input — touchpad (ported from x11/30-touchpad.conf; sway uses libinput too)
input "type:touchpad" {
    tap enabled              # tap-to-click
    tap_button_map lrm       # 1 finger=left, 2=right, 3=middle
    drag enabled             # tap-and-drag
    drag_lock disabled
    click_method clickfinger # physical click: 1=left, 2=right, 3=middle
    scroll_method two_finger
    natural_scroll enabled   # content follows fingers
    dwt enabled              # disable while typing
    scroll_factor 0.5        # halve scroll speed (replaces the X11 custom accel curve)
}

### Floating window rules
for_window [app_id="thunar"] floating enable
for_window [class="Thunar"] floating enable
for_window [app_id="blueman-manager"] floating enable
for_window [class="Blueman-manager"] floating enable

# Drag tiling windows by the titlebar (sway default)
tiling_drag enable
floating_modifier $mod

### Key bindings — applications
bindsym $mod+Return exec $term
bindsym $mod+Shift+q kill
bindsym $mod+d exec fuzzel

# Window switcher — list every window across all workspaces and focus the pick.
# This is what lets windows stay titlebar-less: find windows on demand instead
# of reading always-visible titlebars. Searches app id + title. (sway/window-switcher.py)
bindsym $mod+Tab exec ~/.config/sway/window-switcher.py

# fuzzy-find a file under $HOME and open it. fuzzel --dmenu handles 20k+ items
# fast (wmenu lays out the whole list in software and lags on big inputs).
bindsym $mod+p exec sh -c 'f=$(fd -t f . "$HOME" | fuzzel --dmenu) && [ -n "$f" ] && xdg-open "$f"'

# Clipboard history (clipmenu on X11) — cliphist stores, wmenu picks.
bindsym $mod+v exec sh -c 'cliphist list | fuzzel --dmenu | cliphist decode | wl-copy'

# Color picker (xcolor on X11) — hyprpicker copies the hex to the clipboard.
bindsym $mod+c exec hyprpicker -a

### Key bindings — focus
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

### Key bindings — move
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

### Key bindings — layout
bindsym $mod+f fullscreen toggle
bindsym $mod+q layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent
bindsym $mod+b focus child

### Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

### Session control
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r reload
bindsym $mod+Shift+x exec $lock
bindsym $mod+Shift+BackSpace exec swaynag -t warning \
    -m 'Power menu' \
    -B 'Lock' "$lock" \
    -B 'Logout' 'swaymsg exit' \
    -B 'Suspend' 'systemctl suspend' \
    -B 'Reboot' 'systemctl reboot' \
    -B 'Poweroff' 'systemctl poweroff'
bindsym Control+Mod1+BackSpace exec systemctl suspend

### Resize mode
mode "resize" {
    bindsym $down resize shrink width 10 px
    bindsym $up resize grow height 10 px
    bindsym $right resize shrink height 10 px
    bindsym semicolon resize grow width 10 px
    bindsym Left resize shrink width 10 px
    bindsym Down resize grow height 10 px
    bindsym Up resize shrink height 10 px
    bindsym Right resize grow width 10 px
    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

### Media / hardware keys (--locked so they work on the lock screen)
bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym --locked XF86AudioMute exec pactl set-sink-mute @DEFAULT_SINK@ toggle
bindsym --locked XF86AudioMicMute exec pactl set-source-mute @DEFAULT_SOURCE@ toggle
bindsym --locked XF86MonBrightnessUp exec brightnessctl set +5%
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym --locked XF86AudioPlay exec playerctl play-pause
bindsym --locked XF86AudioNext exec playerctl next
bindsym --locked XF86AudioPrev exec playerctl previous

### Screenshots (grim/slurp/wl-copy replace maim/xclip)
bindsym Shift+Print exec grim -g "$(slurp)" ~/Images/Screenshots/$(date +%F_%H-%M-%S).png
# Region shot: save to a file AND copy to clipboard, then notify with the path
# (a saved file is the reliable way to attach into terminal apps like Claude Code).
bindsym Print exec sh -c 'f=~/Images/Screenshots/$(date +%F_%H-%M-%S).png; grim -g "$(slurp)" "$f" && wl-copy < "$f" && notify-send "Screenshot" "$f"'

### Appearance
# No chrome at all: no titlebar and no border around windows. Tabbed/stacked
# layouts (mod+w / mod+q) still show their tab strip — that's intrinsic to the
# layout — but nothing else draws a frame. (To bring back a 1px focus border:
# default_border pixel 1)
default_border none
default_floating_border none
hide_edge_borders none

# Tabbed/stacked tabs are the only place titles show (tiling is titlebar-less).
# Compact padding, left-aligned labels.
titlebar_padding 8 2
title_align left

gaps inner 4
gaps outer 2
smart_gaps off

# The window color language. Text colors are tuned for tab legibility (the only
# place titles render): every tab label stays readable, with a clear
# focused > active-tab > other-tab hierarchy.
#   focused          = muted dark-blue fill, light text (no frame line)
#   focused_inactive = selected tab of an unfocused group: light text on surface
#   unfocused        = other tabs in the strip: muted-but-readable label on surface
#   urgent           = red fill, demands attention
# Each state's border matches its own background, so tabs are flat — no frame
# line around any title. Focus is signalled by fill/text alone.
#
# class                 border    background  text     indicator  child_border
client.focused          $sel      $sel        $fg      $accent2   $sel
client.focused_inactive $bg_alt   $bg_alt     $fg      $sel       $bg_alt
client.unfocused        $bg_alt   $bg_alt     $muted   $bg_alt    $bg_alt
client.urgent           $urgent   $urgent     $bg      $urgent    $urgent
client.placeholder      $bg_alt   $bg_alt     $fg      $bg_alt    $bg_alt
client.background       $bg

# Status bar is Waybar, launched via exec_always above (no sway `bar {}` block).
