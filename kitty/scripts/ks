#!/usr/bin/env python3
"""ks - kitty session helper.
Env vars:
  KS_LOCATIONS      Colon-separated parent dirs for `-n` candidate enumeration.
  KS_TEMPLATE       Path to session-file template (default: ~/.config/kitty/sessions/template.kitty-session).
  KS_SESSIONS_DIR   Directory of *.kitty-session files for `-n` (default: ~/.config/kitty/sessions).
"""

from __future__ import annotations

import glob
import json
import os
import re
import shlex
import shutil
import socket as _socket
import subprocess
import sys
import time
from dataclasses import dataclass


HOME = os.environ.get("HOME", "")

KS_STATE_FILE = os.environ.get("KS_STATE_FILE") or os.path.join(
    os.environ.get("XDG_CACHE_HOME") or os.path.join(HOME, ".cache"),
    "ks",
    "sessions.json",
)


def _state_load() -> list[dict]:
    try:
        with open(KS_STATE_FILE) as f:
            data = json.load(f)
        return data if isinstance(data, list) else []
    except (OSError, json.JSONDecodeError, ValueError):
        return []


def _state_save(entries: list[dict]) -> None:
    try:
        os.makedirs(os.path.dirname(KS_STATE_FILE), exist_ok=True)
        tmp = KS_STATE_FILE + ".tmp"
        with open(tmp, "w") as f:
            json.dump(entries, f, indent=2)
        os.replace(tmp, KS_STATE_FILE)
    except OSError as e:
        sys.stderr.write(f"ks: warning: could not write state file: {e}\n")

# Pinned protocol version for direct unix-socket RC. Must be <= installed kitty
# version. 0.14.2 is conservative — modern kittys (≥0.14.2, which is years old)
# accept it; older kittys would reject with a clear error.
KITTY_RC_VERSION = [0, 14, 2]


def resolve_socket() -> str:
    listen = os.environ.get("KITTY_LISTEN_ON")
    if listen:
        return listen
    candidates = sorted(
        glob.glob("/tmp/mykitty-*"),
        key=lambda p: os.path.getmtime(p),
        reverse=True,
    )
    if not candidates:
        sys.stderr.write(
            "ks: no kitty socket found (is kitty running with listen_on?)\n"
        )
        sys.exit(1)
    return "unix:" + candidates[0]


SOCKET = resolve_socket()
SOCKET_PATH = SOCKET[len("unix:") :] if SOCKET.startswith("unix:") else ""


# --- low-level helpers ---


def strip_private(p: str) -> str:
    return p[len("/private") :] if p.startswith("/private/") else p


def kitty_at(*args: str, check: bool = True) -> str:
    cmd = ["kitty", "@", "--to", SOCKET, *args]
    res = subprocess.run(cmd, capture_output=True, text=True)
    if res.returncode != 0:
        if check:
            sys.stderr.write("ks: " + " ".join(shlex.quote(a) for a in cmd) + "\n")
            sys.stderr.write("ks: " + res.stderr.strip() + "\n")
            sys.exit(1)
        return ""
    return res.stdout.strip()


def _socket_rc(payload: dict, timeout: float = 5.0) -> dict:
    """Send one command directly over kitty's RC unix socket. ~30× faster than
    spawning `kitty @` because we skip a full kitty interpreter startup."""
    payload.setdefault("version", KITTY_RC_VERSION)
    payload.setdefault("no_response", False)
    msg = b"\x1bP@kitty-cmd" + json.dumps(payload).encode() + b"\x1b\\"
    s = _socket.socket(_socket.AF_UNIX, _socket.SOCK_STREAM)
    s.settimeout(timeout)
    buf = b""
    try:
        s.connect(SOCKET_PATH)
        s.sendall(msg)
        while True:
            chunk = s.recv(65536)
            if not chunk:
                break
            buf += chunk
            if buf.endswith(b"\x1b\\"):
                break
    finally:
        s.close()
    if not buf.startswith(b"\x1bP@kitty-cmd") or not buf.endswith(b"\x1b\\"):
        raise RuntimeError("ks: unexpected response framing from kitty socket")
    return json.loads(buf[len(b"\x1bP@kitty-cmd") : -2])


def kitty_ls() -> list:
    # Fast path: direct unix-socket RC. Falls back to `kitty @ ls` subprocess
    # only when listen_on isn't a unix socket (e.g. tcp:) or the socket call
    # fails for any reason.
    if SOCKET_PATH:
        try:
            resp = _socket_rc({"cmd": "ls"})
        except (OSError, RuntimeError, _socket.timeout, json.JSONDecodeError):
            resp = None
        if resp is not None:
            if not resp.get("ok"):
                sys.stderr.write(
                    f"ks: kitty RC error: {resp.get('error', 'unknown')}\n"
                )
                sys.exit(1)
            data = resp.get("data")
            if isinstance(data, str):
                try:
                    return json.loads(data)
                except (json.JSONDecodeError, ValueError):
                    return []
            if isinstance(data, list):
                return data
            return []
    raw = kitty_at("ls")
    try:
        return json.loads(raw)
    except (json.JSONDecodeError, ValueError):
        return []


# --- domain ---


@dataclass
class SessionRow:
    name: str
    cwd: str
    launch_path: str
    focused: bool
    last_focused_at: float


def _os_window_id_for(window_id: int, data: list | None = None) -> int | None:
    """Look up the OS window id that owns `window_id`."""
    if data is None:
        data = kitty_ls()
    for o in data:
        for t in o.get("tabs", []):
            for w in t.get("windows", []):
                if w.get("id") == window_id:
                    return o.get("id")
    return None


def _state_record(name: str, os_window_id: int, initial_cwd: str) -> None:
    """Persist a new session, replacing any prior entry on this socket that
    collides on either name or os_window_id."""
    entries = _state_load()
    pruned = [
        e
        for e in entries
        if not (
            e.get("socket") == SOCKET_PATH
            and (e.get("name") == name or e.get("os_window_id") == os_window_id)
        )
    ]
    pruned.append(
        {
            "name": name,
            "os_window_id": os_window_id,
            "socket": SOCKET_PATH,
            "cwd": initial_cwd,
            "session_path": initial_cwd,
            "created_at": time.time(),
        }
    )
    _state_save(pruned)


def _window_session_name(w: dict) -> str:
    """Read a session name from kitty's built-in top-level field first, then
    fall back to the user_var we set ourselves. Either is good enough to tag
    the OS window as a session."""
    return w.get("session_name") or (w.get("user_vars") or {}).get("session_name") or ""


def _builtin_session_name_for_os_window(os_win: dict) -> str:
    """First non-empty session_name found anywhere in this OS window. Used as
    fallback detection for OS windows started via `startup_session` /
    `kitty --session`, where the built-in field auto-propagates to every
    window."""
    for tab in os_win.get("tabs", []):
        for w in tab.get("windows", []):
            n = _window_session_name(w)
            if n:
                return n
    return ""


def find_current_session_name(data: list) -> str | None:
    """The session you're currently "in" (the focused OS window). Tries the
    state file first (so it works after the originally-tagged window has been
    closed), then falls back to scanning windows for a session_name."""
    focused_os: dict | None = None
    for os_win in data:
        if os_win.get("is_focused"):
            focused_os = os_win
            break
    if focused_os is None:
        return None
    os_id = focused_os.get("id")
    for e in _state_load():
        if e.get("socket") == SOCKET_PATH and e.get("os_window_id") == os_id:
            return e.get("name")
    best_name: str | None = None
    best_t = -1.0
    for tab in focused_os.get("tabs", []):
        for w in tab.get("windows", []):
            name = _window_session_name(w)
            if not name:
                continue
            t = float(w.get("last_focused_at") or 0)
            if t > best_t:
                best_name, best_t = name, t
    return best_name


def _build_row_for_os_window(
    os_win: dict, name: str, launch_path: str, fallback_cwd: str
) -> SessionRow:
    """Collapse an OS window into a SessionRow.

    The cwd we display is intentionally stable, not "wherever the user last cd'd
    to". Using a most-recently-focused rep means the picker shows the cwd of
    whatever transient window happened to grab focus last — including the very
    overlay running `ks -i`. Instead:
      * state-file sessions → the recorded launch path
      * built-in (startup_session) sessions → the cwd of the *earliest* window
        carrying the session_name tag (i.e. the original launch window)
    """
    os_focused = bool(os_win.get("is_focused"))
    last_t = 0.0
    is_session_focused = False

    builtin_cwd = ""
    builtin_id: int | None = None

    for tab in os_win.get("tabs", []):
        tab_focused = bool(tab.get("is_focused"))
        for w in tab.get("windows", []):
            t = float(w.get("last_focused_at") or 0)
            if t > last_t:
                last_t = t
            if os_focused and tab_focused and bool(w.get("is_focused")):
                is_session_focused = True
            if not launch_path and _window_session_name(w) == name:
                wid = w.get("id")
                if isinstance(wid, int) and (builtin_id is None or wid < builtin_id):
                    fg = w.get("foreground_processes") or []
                    builtin_cwd = (
                        (fg[0].get("cwd") if fg else None) or w.get("cwd", "") or ""
                    )
                    builtin_id = wid

    cwd = strip_private(launch_path or builtin_cwd or fallback_cwd)
    return SessionRow(
        name=name,
        cwd=cwd,
        launch_path=strip_private(launch_path) or cwd,
        focused=is_session_focused,
        last_focused_at=last_t,
    )


def list_sessions(data: list | None = None) -> list[SessionRow]:
    if data is None:
        data = kitty_ls()

    live_os = {o.get("id"): o for o in data if o.get("id") is not None}

    # Lazy prune: drop state entries for this socket whose OS window is gone.
    entries = _state_load()
    pruned: list[dict] = []
    changed = False
    for e in entries:
        if e.get("socket") == SOCKET_PATH and e.get("os_window_id") not in live_os:
            changed = True
            continue
        pruned.append(e)
    if changed:
        _state_save(pruned)

    rows_by_os: dict[int, SessionRow] = {}

    # 1. Sessions from the state file (current socket only).
    for e in pruned:
        if e.get("socket") != SOCKET_PATH:
            continue
        os_id = e.get("os_window_id")
        os_win = live_os.get(os_id)
        if os_win is None:
            continue
        rows_by_os[os_id] = _build_row_for_os_window(
            os_win,
            name=e.get("name", ""),
            launch_path=e.get("session_path") or e.get("cwd", ""),
            fallback_cwd=e.get("cwd", ""),
        )

    # 2. Fallback: OS windows kitty itself tagged via startup_session /
    #    --session, but that we don't have a state entry for.
    for os_id, os_win in live_os.items():
        if os_id in rows_by_os:
            continue
        name = _builtin_session_name_for_os_window(os_win)
        if not name:
            continue
        rows_by_os[os_id] = _build_row_for_os_window(
            os_win, name=name, launch_path="", fallback_cwd=""
        )

    return sorted(
        rows_by_os.values(),
        key=lambda r: (-int(r.focused), -r.last_focused_at, r.name),
    )


def extract_session_name_from_file(path: str) -> str | None:
    """Return the --var=session_name=... value from the first `launch` directive
    in a session file, or None. Skips comments and non-launch directives
    (os_window_title, cd, etc.) that may appear before the first launch.
    """
    try:
        with open(path) as f:
            for raw in f:
                line = raw.strip()
                if not line or line.startswith("#"):
                    continue
                if line.split()[0] != "launch":
                    continue
                m = re.search(r"--var=session_name=(\S+)", line)
                return m.group(1) if m else None
    except OSError:
        return None
    return None


def session_is_running(name: str) -> bool:
    data = kitty_ls()
    live_os = {o.get("id") for o in data if o.get("id") is not None}
    for e in _state_load():
        if (
            e.get("socket") == SOCKET_PATH
            and e.get("name") == name
            and e.get("os_window_id") in live_os
        ):
            return True
    for os_win in data:
        for tab in os_win.get("tabs", []):
            for w in tab.get("windows", []):
                if _window_session_name(w) == name:
                    return True
    return False


def apply_session_file(path: str, session_name: str, initial_cwd: str) -> int:
    """Render and replay a (possibly templated) kitty session file as `kitty @`
    calls against the running kitty over SOCKET. Returns 0 on success, 1 on error.
    """
    try:
        with open(path) as f:
            text = f.read()
    except OSError as e:
        sys.stderr.write(f"ks: cannot read session file: {path}: {e}\n")
        return 1

    text = text.replace("${KS_CWD}", initial_cwd).replace(
        "${KS_SESSION_NAME}", session_name
    )

    cwd = initial_cwd
    os_window_title = session_name or os.path.basename(path)
    first_launch_done = False
    last_window_id: str | None = None
    focused_window_id: str | None = None
    tag_match: str | None = None

    def extract_tag(launch_args: list[str]) -> str | None:
        for a in launch_args:
            m = re.match(r"--var=session_name=(.+)$", a)
            if m:
                return m.group(1)
        return None

    for raw in text.splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        parts = shlex.split(line)
        directive, rest = parts[0], parts[1:]

        if directive == "cd":
            target = rest[0] if rest else cwd
            target = os.path.expanduser(target)
            cwd = (
                target
                if os.path.isabs(target)
                else os.path.abspath(os.path.join(cwd, target))
            )
        elif directive == "os_window_title":
            os_window_title = " ".join(rest)
        elif directive == "launch":
            is_first = not first_launch_done
            if is_first:
                args = [
                    "launch",
                    "--type=os-window",
                    "--cwd=" + cwd,
                    "--os-window-title=" + os_window_title,
                    *rest,
                ]
                tag_match = "var:session_name=" + (
                    session_name or extract_tag(rest) or ""
                )
            else:
                match = (
                    ("id:" + last_window_id) if last_window_id else (tag_match or "")
                )
                args = ["launch", "--match", match, "--cwd=" + cwd, *rest]
            wid = kitty_at(*args)
            if wid.isdigit():
                last_window_id = wid
            if is_first and session_name and wid.isdigit():
                os_win_id = _os_window_id_for(int(wid))
                if os_win_id is not None:
                    _state_record(session_name, os_win_id, initial_cwd)
            first_launch_done = True
        elif directive == "new_tab":
            match = ("id:" + last_window_id) if last_window_id else (tag_match or "")
            args = ["launch", "--type=tab", "--match", match, "--cwd=" + cwd]
            if rest:
                args.append("--tab-title=" + " ".join(rest))
            wid = kitty_at(*args)
            if wid.isdigit():
                last_window_id = wid
        elif directive == "focus":
            focused_window_id = last_window_id
        elif directive == "focus_os_window":
            pass
        else:
            sys.stderr.write(
                f"ks: warning: unsupported session-file directive: {directive}\n"
            )

    if not first_launch_done:
        sys.stderr.write("ks: session file defined no launch directives\n")
        return 1

    if focused_window_id:
        kitty_at("focus-window", "--match", "id:" + focused_window_id)
    return 0


def create_session(abs_path: str) -> str:
    folder_name = os.path.basename(abs_path)
    uid = os.urandom(3).hex()
    session_name = f"{folder_name}-{uid}"
    template = os.environ.get("KS_TEMPLATE") or os.path.join(
        HOME, ".config/kitty/sessions/template.kitty-session"
    )
    if not os.access(template, os.R_OK):
        sys.stderr.write(f"ks: template not found or unreadable: {template}\n")
        sys.stderr.write(
            "ks: set KS_TEMPLATE to override, or create the default template\n"
        )
        pause_overlay()
        sys.exit(1)
    if apply_session_file(template, session_name, abs_path) != 0:
        pause_overlay()
        sys.exit(1)
    return session_name


def launch_session_file(path: str) -> None:
    name = extract_session_name_from_file(path)
    if name and session_is_running(name):
        cmd_switch(name)
        return
    if apply_session_file(path, name or "", HOME) != 0:
        pause_overlay()
        sys.exit(1)
    if name:
        print(name)


def _state_drop_name(name: str) -> None:
    entries = _state_load()
    new_entries = [
        e
        for e in entries
        if not (e.get("socket") == SOCKET_PATH and e.get("name") == name)
    ]
    if len(new_entries) != len(entries):
        _state_save(new_entries)


def kill_session_by_name(name: str) -> bool:
    data = kitty_ls()
    live_os = {o.get("id"): o for o in data if o.get("id") is not None}

    target_os_id: int | None = None
    for e in _state_load():
        if (
            e.get("socket") == SOCKET_PATH
            and e.get("name") == name
            and e.get("os_window_id") in live_os
        ):
            target_os_id = e.get("os_window_id")
            break

    if target_os_id is None:
        for os_win in data:
            for tab in os_win.get("tabs", []):
                if any(_window_session_name(w) == name for w in tab.get("windows", [])):
                    target_os_id = os_win.get("id")
                    break
            if target_os_id is not None:
                break

    if target_os_id is None:
        return False

    os_win = live_os[target_os_id]
    for tab in os_win.get("tabs", []):
        for w in tab.get("windows", []):
            wid = w.get("id")
            if wid is not None:
                kitty_at("close-window", "--match", "id:" + str(wid), check=False)

    _state_drop_name(name)
    return True


# --- display + fzf ---


def display_cwd(p: str) -> str:
    if HOME and p.startswith(HOME):
        return "~" + p[len(HOME) :]
    return p


def format_session_table(rows: list[SessionRow]) -> list[tuple[str, str]]:
    """Returns [(name, fzf-display-line), ...] shared by cmd_list/-i/-k."""
    if not rows:
        return []
    name_w = max(len(r.name) for r in rows)
    out: list[tuple[str, str]] = []
    for r in rows:
        out.append((r.name, f"{r.name:<{name_w}}  {display_cwd(r.cwd)}"))
    return out


def pause_overlay() -> None:
    if not sys.stderr.isatty():
        return
    try:
        sys.stderr.write("ks: press any key to close...")
        sys.stderr.flush()
        with open("/dev/tty", "rb", buffering=0) as tty:
            tty.read(1)
        sys.stderr.write("\n")
    except OSError:
        pass


def load_fzf_env() -> None:
    """Populate FZF_DEFAULT_OPTS from ~/.config/zsh/fzf.sh if not already set.

    kitty launched from the Dock/Spotlight doesn't inherit zsh exports, so when
    `ks` is triggered by an overlay keybinding the FZF theme env isn't in the
    environment. The bash launcher used to source fzf.sh — we now do the same
    inline (single-quoted multi-line and double-quoted single-line `export`s),
    and only for the picker paths that actually run fzf.
    """
    if os.environ.get("FZF_DEFAULT_OPTS"):
        return
    path = os.path.join(HOME, ".config/zsh/fzf.sh")
    try:
        with open(path) as f:
            text = f.read()
    except OSError:
        return
    m = re.search(
        r"^[ \t]*export[ \t]+FZF_DEFAULT_OPTS=(['\"])(.*?)\1",
        text,
        re.DOTALL | re.MULTILINE,
    )
    if m:
        os.environ["FZF_DEFAULT_OPTS"] = m.group(2)


def require_fzf() -> None:
    if shutil.which("fzf") is None:
        sys.stderr.write("ks: fzf not found in PATH (brew install fzf)\n")
        pause_overlay()
        sys.exit(1)
    load_fzf_env()


def run_fzf(
    lines: list[str],
    *,
    prompt: str,
    header: str,
    multi: bool,
    with_nth: int,
    delimiter: str = "\t",
) -> list[str] | None:
    """Run fzf over `lines`. Returns selected lines, or None on cancel."""
    cmd = [
        "fzf",
        "--ansi",
        "--reverse",
        "--height=40%",
        f"--with-nth={with_nth}",
        f"--delimiter={delimiter}",
        f"--prompt={prompt}",
        f"--header={header}",
    ]
    cmd.append("--multi" if multi else "--no-multi")
    res = subprocess.run(
        cmd,
        input="\n".join(lines),
        capture_output=True,
        text=True,
    )
    # fzf exit: 0 = match, 1 = no match, 2 = error, 130 = ctrl-c/esc
    if res.returncode != 0:
        return None
    out = res.stdout.strip("\n")
    if not out:
        return None
    return out.split("\n")


# --- commands ---


def cmd_list() -> None:
    data = kitty_ls()
    rows = list_sessions(data)
    if not rows:
        return
    current = find_current_session_name(data)
    name_w = max(len(r.name) for r in rows)
    for r in rows:
        marker = "*" if r.name == current else " "
        print(f"{marker} {r.name:<{name_w}}  {display_cwd(r.cwd)}")


def cmd_switch(name: str) -> None:
    data = kitty_ls()
    live_os = {o.get("id"): o for o in data if o.get("id") is not None}

    target_os_id: int | None = None
    for e in _state_load():
        if (
            e.get("socket") == SOCKET_PATH
            and e.get("name") == name
            and e.get("os_window_id") in live_os
        ):
            target_os_id = e.get("os_window_id")
            break
    if target_os_id is None:
        for os_win in data:
            for tab in os_win.get("tabs", []):
                if any(_window_session_name(w) == name for w in tab.get("windows", [])):
                    target_os_id = os_win.get("id")
                    break
            if target_os_id is not None:
                break

    if target_os_id is None:
        sys.stderr.write(f"ks: no session named '{name}'\n")
        sys.exit(1)

    # Pick a window to focus inside the target OS window: prefer the active
    # tab's active window so focus lands where the user left it.
    os_win = live_os[target_os_id]
    target_wid: int | None = None
    for tab in os_win.get("tabs", []):
        if not tab.get("is_active"):
            continue
        for w in tab.get("windows", []):
            if w.get("is_active"):
                target_wid = w.get("id")
                break
        if target_wid is None:
            for w in tab.get("windows", []):
                target_wid = w.get("id")
                break
        break
    if target_wid is None:
        for tab in os_win.get("tabs", []):
            for w in tab.get("windows", []):
                target_wid = w.get("id")
                break
            if target_wid is not None:
                break

    if target_wid is None:
        sys.stderr.write(f"ks: session '{name}' has no windows to focus\n")
        sys.exit(1)

    cmd = [
        "kitty",
        "@",
        "--to",
        SOCKET,
        "focus-window",
        "--match",
        f"id:{target_wid}",
    ]
    res = subprocess.run(cmd, capture_output=True, text=True)
    if res.returncode != 0:
        err = res.stderr.strip()
        sys.stderr.write(f"ks: {err or 'failed to focus session ' + repr(name)}\n")
        sys.exit(1)


def cmd_kill(names: list[str]) -> None:
    missing = [n for n in names if not kill_session_by_name(n)]
    if missing:
        for n in missing:
            sys.stderr.write(f"ks: no session named '{n}'\n")
        sys.exit(1)


def cmd_kill_all() -> None:
    data = kitty_ls()
    live_os = {o.get("id"): o for o in data if o.get("id") is not None}
    focused_os = None
    for os_id, os_win in live_os.items():
        if os_win.get("is_focused"):
            focused_os = os_id
            break
    if focused_os is None:
        sys.stderr.write("ks: could not identify the focused kitty OS window\n")
        sys.exit(2)

    state_os_ids = {
        e.get("os_window_id")
        for e in _state_load()
        if e.get("socket") == SOCKET_PATH and e.get("os_window_id") in live_os
    }

    ids: list[str] = []
    killed_os_ids: set[int] = set()
    for os_id, os_win in live_os.items():
        if os_id == focused_os:
            continue
        has_session = os_id in state_os_ids or any(
            _window_session_name(w)
            for tab in os_win.get("tabs", [])
            for w in tab.get("windows", [])
        )
        if not has_session:
            continue
        killed_os_ids.add(os_id)
        for tab in os_win.get("tabs", []):
            for w in tab.get("windows", []):
                wid = w.get("id")
                if wid is not None:
                    ids.append(str(wid))

    if not ids:
        sys.stderr.write("ks: no other sessions to kill\n")
        return

    count = 0
    for wid in ids:
        kitty_at("close-window", "--match", "id:" + wid, check=False)
        count += 1

    if killed_os_ids:
        entries = _state_load()
        new_entries = [
            e
            for e in entries
            if not (
                e.get("socket") == SOCKET_PATH
                and e.get("os_window_id") in killed_os_ids
            )
        ]
        if len(new_entries) != len(entries):
            _state_save(new_entries)

    sys.stderr.write(f"ks: closed {count} session window(s)\n")


def cmd_pick_session() -> None:
    require_fzf()
    data = kitty_ls()
    rows = list_sessions(data)
    if not rows:
        sys.stderr.write("ks: no active sessions\n")
        pause_overlay()
        return
    # The overlay grabs focus, so kitty no longer reports any session window as
    # focused. To put the *previously* focused (= last visited) session at the
    # fzf cursor and the user's current session at the bottom, identify the
    # current session from the focused tab and rank it last.
    current_name = find_current_session_name(data)
    rows = sorted(
        rows,
        key=lambda r: (r.name == current_name, -r.last_focused_at),
    )
    table = format_session_table(rows)
    name_w = max(len(n) for n, _ in table)
    lines = [
        f"{name}\t{name:<{name_w}}  {display_cwd(r.cwd)}"
        for (name, _), r in zip(table, rows)
    ]
    chosen = run_fzf(
        lines,
        prompt="session > ",
        header="Enter: switch • Esc: cancel",
        multi=False,
        with_nth=2,
    )
    if not chosen:
        return
    name = chosen[0].split("\t", 1)[0]
    cmd_switch(name)


def cmd_pick_kill() -> None:
    require_fzf()
    rows = list_sessions()
    if not rows:
        sys.stderr.write("ks: no active sessions\n")
        pause_overlay()
        return
    # Ascending: focused session lands at bottom of the fzf list — safer default
    # when the action is destructive.
    rows = sorted(rows, key=lambda r: (r.focused, r.last_focused_at))
    table = format_session_table(rows)
    name_w = max(len(n) for n, _ in table)
    lines = [
        f"{name}\t{name:<{name_w}}  {display_cwd(r.cwd)}"
        for (name, _), r in zip(table, rows)
    ]
    chosen = run_fzf(
        lines,
        prompt="kill > ",
        header="Tab: select • Enter: kill • Esc: cancel",
        multi=True,
        with_nth=2,
    )
    if not chosen:
        return
    killed = 0
    for line in chosen:
        name = line.split("\t", 1)[0]
        if kill_session_by_name(name):
            killed += 1
    sys.stderr.write(f"ks: killed {killed} session(s)\n")


def cmd_pick_new() -> None:
    require_fzf()
    locations = os.environ.get("KS_LOCATIONS", "")
    if not locations:
        sys.stderr.write(
            "ks: KS_LOCATIONS is not set.\n"
            'Example: export KS_LOCATIONS="$HOME/projects:$HOME/.config"\n'
        )
        pause_overlay()
        sys.exit(1)

    locs = [os.path.expanduser(p) for p in locations.split(":") if p]
    sessions_dir = os.environ.get("KS_SESSIONS_DIR") or os.path.join(
        HOME, ".config/kitty/sessions"
    )

    data = kitty_ls()
    active_paths: set[str] = set()
    active_names: set[str] = set()
    for os_win in data:
        for tab in os_win.get("tabs", []):
            for w in tab.get("windows", []):
                uv = w.get("user_vars") or {}
                name = uv.get("session_name")
                if not name:
                    continue
                active_names.add(name)
                fg = w.get("foreground_processes") or []
                cwd = (fg[0].get("cwd") if fg else None) or w.get("cwd", "")
                active_paths.add(strip_private(uv.get("session_path") or cwd))

    # Directory candidates under KS_LOCATIONS (not already a running session).
    seen: set[str] = set()
    dirs: list[tuple[str, str]] = []  # (label, abs_path)
    for loc in locs:
        if not os.path.isdir(loc):
            continue
        try:
            names = sorted(os.listdir(loc))
        except OSError:
            continue
        for n in names:
            if n.startswith("."):
                continue
            full = os.path.join(loc, n)
            if not os.path.isdir(full):
                continue
            try:
                abs_full = strip_private(os.path.realpath(full))
            except OSError:
                abs_full = strip_private(full)
            if abs_full in active_paths or abs_full in seen:
                continue
            seen.add(abs_full)
            dirs.append((os.path.basename(abs_full), abs_full))
    dirs.sort(key=lambda x: (x[0].lower(), x[1]))

    # Session-file candidates (sessions_dir/*.kitty-session, excluding template).
    sessions: list[tuple[str, str, bool]] = []  # (label, full_path, running)
    if sessions_dir and os.path.isdir(sessions_dir):
        try:
            entries = sorted(os.listdir(sessions_dir))
        except OSError:
            entries = []
        for n in entries:
            if n.startswith(".") or not n.endswith(".kitty-session"):
                continue
            if n == "template.kitty-session":
                continue
            full = os.path.join(sessions_dir, n)
            baked = extract_session_name_from_file(full)
            label = n[: -len(".kitty-session")]
            running = bool(baked) and baked in active_names
            sessions.append((label, full, running))
    sessions.sort(key=lambda x: x[0].lower())

    if not dirs and not sessions:
        sys.stderr.write("ks: no available directories or session files\n")
        pause_overlay()
        return

    label_w = max([len(s[0]) for s in sessions] + [len(d[0]) for d in dirs] + [0])

    lines: list[str] = []
    for label, full, running in sessions:
        suffix = "  (running)" if running else ""
        lines.append(f"session\t{full}\t[session] {label:<{label_w}}{suffix}")
    for label, abs_full in dirs:
        lines.append(
            f"dir\t{abs_full}\t[dir]     {label:<{label_w}}  {display_cwd(abs_full)}"
        )

    chosen = run_fzf(
        lines,
        prompt="new > ",
        header="Tab: select • Enter: open • Esc: cancel",
        multi=True,
        with_nth=3,
    )
    if not chosen:
        return
    for line in chosen:
        parts = line.split("\t", 2)
        if len(parts) < 2:
            continue
        kind, selector = parts[0], parts[1]
        if kind == "session":
            launch_session_file(selector)
        elif kind == "dir":
            name = create_session(selector)
            print(name)
        else:
            sys.stderr.write(f"ks: unknown selection type: {kind}\n")
            pause_overlay()
            sys.exit(1)


# --- dispatch ---


USAGE = """Usage:
  ks <path> ...    Open a kitty OS window per path, tagged session_name=<folder>-<uid>.
  ks -l            List all active kitty sessions.
  ks -s <name>     Switch focus to the session with the given name.
  ks -k            Interactive picker (fzf, multi-select) over active sessions; kill on Enter.
  ks -k <name> ... Close the named session(s) (closes their OS windows).
  ks -k --all      Close all sessions except the currently focused one.
  ks -i            Interactive picker (fzf) over active sessions; switch on select.
  ks -n            Interactive picker (fzf, multi-select) over KS_LOCATIONS subdirs; create on Enter.
"""


def main(argv: list[str]) -> int:
    if not argv:
        sys.stderr.write(USAGE)
        return 1

    head = argv[0]
    rest = argv[1:]

    if head in ("-h", "--help"):
        sys.stdout.write(USAGE)
        return 0
    if head in ("-l", "--list"):
        cmd_list()
        return 0
    if head in ("-s", "--switch"):
        if not rest or not rest[0]:
            sys.stderr.write("ks: -s requires a session name\n")
            return 1
        cmd_switch(rest[0])
        return 0
    if head in ("-k", "--kill"):
        if not rest or not rest[0]:
            cmd_pick_kill()
        elif rest[0] in ("--all", "-a"):
            cmd_kill_all()
        else:
            cmd_kill(rest)
        return 0
    if head in ("-i", "--interactive"):
        cmd_pick_session()
        return 0
    if head in ("-n", "--new"):
        cmd_pick_new()
        return 0

    paths = [head, *rest]
    for p in paths:
        if not os.path.isdir(p):
            sys.stderr.write(f"ks: not a directory: {p}\n")
            return 1
    for p in paths:
        name = create_session(os.path.abspath(p))
        print(name)
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main(sys.argv[1:]))
    except KeyboardInterrupt:
        sys.exit(130)
