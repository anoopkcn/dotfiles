#!/usr/bin/env bash
# ks - kitty session helper. Thin launcher that sources fzf options so the
# FZF_* env vars propagate to fzf (spawned by ks.py), then execs ks.py.
# All logic lives in ks.py; see `ks -h` for usage.

set -euo pipefail

# kitty's --copy-env can't reach env exported in zshrc when kitty.app is
# launched from the Dock/Spotlight, so source the shared file directly. We
# can't trust $ZDOTDIR here — kitty's shell integration overrides it to its
# own internal path — so try the user config dir first, then fall back.
for _fzf_opts in "$HOME/.config/zsh/fzf.sh" "${ZDOTDIR:-}/fzf.sh"; do
  if [[ -r "$_fzf_opts" ]]; then
    # shellcheck disable=SC1090
    source "$_fzf_opts"
    break
  fi
done
unset _fzf_opts

# Resolve $0 through any symlink chain so ks.py is found next to the *real*
# script (e.g. when invoked via a ~/.local/bin/ks shim).
src="$0"
while [[ -L "$src" ]]; do
  link_dir="$(cd -P "$(dirname "$src")" && pwd)"
  target="$(readlink "$src")"
  [[ "$target" = /* ]] && src="$target" || src="$link_dir/$target"
done
script_dir="$(cd -P "$(dirname "$src")" && pwd)"

exec /usr/bin/env python3 "$script_dir/ks.py" "$@"
