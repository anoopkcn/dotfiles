#!/usr/bin/env bash
# ks - kitty session helper
#
# Usage:
#   ks <path>     Open a new kitty OS window tagged with session_name=<folder>-<uid>.
#   ks -l         List all active kitty sessions.
#   ks -s <name>  Switch focus to the session with the given name.
#   ks -k         Interactive picker (fzf, multi-select) over active sessions; kill on Enter.
#   ks -k <name>  Kill the session with the given name (closes its OS window).
#   ks -k --all   Kill all sessions except the currently focused one.
#   ks -i         Interactive picker (fzf) over active sessions; switch on select.
#   ks -n         Interactive picker (fzf) over KS_LOCATIONS subdirs; create on select.

set -euo pipefail

# Pull in fzf theming so overlays match the interactive shell.
# kitty's --copy-env can't reach env exported in zshrc when kitty.app is
# launched from the Dock/Spotlight, so source the shared file directly. We
# can't trust $ZDOTDIR here — kitty's shell integration overrides it to its
# own internal path — so try the user config dir first, then fall back.
for _fzf_opts in "$HOME/.config/zsh/fzf.sh" "${ZDOTDIR:-}/fzf.sh"; do
  if [[ -r "$_fzf_opts" ]]; then
    # shellcheck disable=SC1090
    source "$_fzf_opts"
    break
  fi
done
unset _fzf_opts

# Resolve the kitty remote-control socket.
# Inside a kitty window, $KITTY_LISTEN_ON is set automatically.
# Otherwise fall back to globbing the listen_on path (kitty appends -<pid>).
if [[ -n "${KITTY_LISTEN_ON:-}" ]]; then
  socket="$KITTY_LISTEN_ON"
else
  socket_path="$(ls -t /tmp/mykitty-* 2>/dev/null | head -n1 || true)"
  if [[ -z "${socket_path:-}" ]]; then
    echo "ks: no kitty socket found (is kitty running with listen_on?)" >&2
    exit 1
  fi
  socket="unix:${socket_path}"
fi

usage() {
  cat <<'EOF'
Usage:
  ks <path>     Open a new kitty OS window tagged with session_name=<folder>-<uid>.
  ks -l         List all active kitty sessions.
  ks -s <name>  Switch focus to the session with the given name.
  ks -k         Interactive picker (fzf, multi-select) over active sessions; kill on Enter.
  ks -k <name>  Kill the session with the given name (closes its OS window).
  ks -k --all   Kill all sessions except the currently focused one.
  ks -i         Interactive picker (fzf) over active sessions; switch on select.
  ks -n         Interactive picker (fzf) over KS_LOCATIONS subdirs; create on select.
EOF
}

require_fzf() {
  if ! command -v fzf >/dev/null 2>&1; then
    echo "ks: fzf not found in PATH (brew install fzf)" >&2
    pause_overlay
    exit 1
  fi
}

# Keep the overlay window open long enough to read an error/notice.
# No-op when stderr is not a tty (e.g. piped invocation).
pause_overlay() {
  if [[ -t 2 ]]; then
    read -n 1 -s -r -p "ks: press any key to close..." </dev/tty >&2 2>/dev/null || true
    echo >&2
  fi
}

# Emits one TSV line per active session, sorted focused-first then most-recent:
#   <name>\t<cwd>\t<launch_path>\t<focused>\t<last_focused_at>
# cwd is the live foreground-process cwd (with /private/ stripped); launch_path
# is the session_path user_var if set, else the cwd.
list_sessions_tsv() {
  kitty @ --to "$socket" ls | python3 -c '
import json, sys

def strip_private(p):
    return p[len("/private"):] if p.startswith("/private/") else p

data = json.load(sys.stdin)
rows = []
for os_win in data:
    os_focused = os_win.get("is_focused", False)
    for tab in os_win.get("tabs", []):
        tab_focused = tab.get("is_focused", False)
        for w in tab.get("windows", []):
            uv = w.get("user_vars") or {}
            name = uv.get("session_name", "")
            if not name:
                continue
            fg = w.get("foreground_processes") or []
            cwd = (fg[0].get("cwd") if fg else None) or w.get("cwd", "")
            cwd = strip_private(cwd)
            launch_path = strip_private(uv.get("session_path") or cwd)
            rows.append({
                "name": name,
                "cwd": cwd,
                "launch_path": launch_path,
                "focused": os_focused and tab_focused and w.get("is_focused", False),
                "last_focused_at": w.get("last_focused_at", 0) or 0,
            })

# Dedupe by session_name: prefer focused, else most-recent.
by_name = {}
for r in rows:
    cur = by_name.get(r["name"])
    if cur is None:
        by_name[r["name"]] = r
        continue
    if r["focused"] and not cur["focused"]:
        by_name[r["name"]] = r
    elif r["focused"] == cur["focused"] and r["last_focused_at"] > cur["last_focused_at"]:
        by_name[r["name"]] = r

items = sorted(by_name.values(), key=lambda r: (-int(r["focused"]), -r["last_focused_at"], r["name"]))
for r in items:
    name = r["name"]
    cwd = r["cwd"]
    launch = r["launch_path"]
    focused = int(r["focused"])
    last = r["last_focused_at"]
    print(f"{name}\t{cwd}\t{launch}\t{focused}\t{last}")
'
}

# Render a (possibly templated) kitty session file and replay its directives as
# `kitty @` calls against the running kitty over $socket, so the new windows
# live in the same process and ks-tracking works.
#
# Args: <file> <session_name> <initial_cwd>
#   session_name is used (a) for ${KS_SESSION_NAME} substitution and (b) for the
#   --match tag on subsequent launches. Pass "" when launching a session file
#   whose tag is hardcoded — the match is then inferred from the first launch.
#
# Supported session-file directives (a subset of kitty's session-file syntax):
#   # ...               comment / blank line — ignored
#   cd <path>           set cwd for subsequent launch directives
#   os_window_title T   title applied to the OS window created by the first launch
#   launch [args...]    first launch creates the OS window; rest open in the same window
#   new_tab [title]     open a new tab inside the session's OS window
#   focus               focus the most recently launched window
#   focus_os_window     no-op (the new OS window is already focused on creation)
apply_session_file() {
  local file="$1" session_name="$2" initial_cwd="$3"
  KS_TEMPLATE_PATH="$file" KS_CWD="$initial_cwd" KS_SESSION_NAME="$session_name" \
    KS_SOCKET="$socket" python3 -c '
import os, re, shlex, subprocess, sys

socket = os.environ["KS_SOCKET"]
session_name = os.environ["KS_SESSION_NAME"]
abs_path = os.environ["KS_CWD"]
template_path = os.environ["KS_TEMPLATE_PATH"]

with open(template_path) as f:
    text = f.read()
text = text.replace("${KS_CWD}", abs_path).replace("${KS_SESSION_NAME}", session_name)

cwd = abs_path
os_window_title = session_name or os.path.basename(template_path)
first_launch_done = False
last_window_id = None
focused_window_id = None
tag_match = None  # set after first launch, from session_name or extracted from launch args

def kitty_at(*args):
    cmd = ["kitty", "@", "--to", socket] + list(args)
    res = subprocess.run(cmd, capture_output=True, text=True)
    if res.returncode != 0:
        sys.stderr.write("ks: " + " ".join(shlex.quote(a) for a in cmd) + "\n")
        sys.stderr.write("ks: " + res.stderr.strip() + "\n")
        sys.exit(1)
    return res.stdout.strip()

def extract_tag(launch_args):
    for a in launch_args:
        m = re.match(r"--var=session_name=(.+)$", a)
        if m:
            return m.group(1)
    return None

for raw in text.splitlines():
    line = raw.strip()
    if not line or line.startswith("#"):
        continue
    parts = shlex.split(line)
    directive, rest = parts[0], parts[1:]
    if directive == "cd":
        target = rest[0] if rest else cwd
        target = os.path.expanduser(target)
        cwd = target if os.path.isabs(target) else os.path.abspath(os.path.join(cwd, target))
    elif directive == "os_window_title":
        os_window_title = " ".join(rest)
    elif directive == "launch":
        if not first_launch_done:
            args = ["launch", "--type=os-window",
                    "--cwd=" + cwd,
                    "--os-window-title=" + os_window_title] + rest
            tag_match = "var:session_name=" + (session_name or extract_tag(rest) or "")
        else:
            # Split / open from the previously launched window so --location
            # behaves deterministically (kitty session file semantics).
            match = ("id:" + last_window_id) if last_window_id else tag_match
            args = ["launch", "--match", match, "--cwd=" + cwd] + rest
        wid = kitty_at(*args)
        if wid.isdigit():
            last_window_id = wid
        first_launch_done = True
    elif directive == "new_tab":
        match = ("id:" + last_window_id) if last_window_id else tag_match
        args = ["launch", "--type=tab", "--match", match or "", "--cwd=" + cwd]
        if rest:
            args.append("--tab-title=" + " ".join(rest))
        wid = kitty_at(*args)
        if wid.isdigit():
            last_window_id = wid
    elif directive == "focus":
        # In kitty session files `focus` marks the preceding launch as the
        # final focused window — apply after all launches complete.
        focused_window_id = last_window_id
    elif directive == "focus_os_window":
        pass
    else:
        sys.stderr.write("ks: warning: unsupported session-file directive: " + directive + "\n")

if not first_launch_done:
    sys.stderr.write("ks: session file defined no launch directives\n")
    sys.exit(1)

if focused_window_id:
    kitty_at("focus-window", "--match", "id:" + focused_window_id)
'
}

# Create a new OS-window session at the given absolute path using the template.
create_session() {
  local abs_path="$1"
  local folder_name uid session_name template
  folder_name="$(basename "$abs_path")"
  uid="$(LC_ALL=C od -An -tx1 -N3 /dev/urandom | tr -d ' \n')"
  session_name="${folder_name}-${uid}"
  template="${KS_TEMPLATE:-$HOME/.config/kitty/sessions/template.kitty-session}"
  if [[ ! -r "$template" ]]; then
    echo "ks: template not found or unreadable: $template" >&2
    echo "ks: set KS_TEMPLATE to override, or create the default template" >&2
    pause_overlay
    exit 1
  fi
  if ! apply_session_file "$template" "$session_name" "$abs_path"; then
    pause_overlay
    exit 1
  fi
  echo "$session_name"
}

# Read a session file's first launch directive and extract --var=session_name=...
# Prints the tag value (or nothing if absent).
extract_session_name_from_file() {
  python3 -c '
import re, sys
try:
    with open(sys.argv[1]) as f:
        for raw in f:
            line = raw.strip()
            if not line or line.startswith("#"):
                continue
            if line.split()[0] == "launch":
                m = re.search(r"--var=session_name=(\S+)", line)
                if m:
                    print(m.group(1))
                break
except OSError:
    sys.exit(1)
' "$1"
}

# Return 0 if a session with the given session_name is currently active.
session_is_running() {
  local name="$1"
  kitty @ --to "$socket" ls 2>/dev/null | python3 -c '
import json, sys
target = sys.argv[1]
try:
    data = json.load(sys.stdin)
except Exception:
    sys.exit(1)
for os_win in data:
    for tab in os_win.get("tabs", []):
        for w in tab.get("windows", []):
            if (w.get("user_vars") or {}).get("session_name") == target:
                sys.exit(0)
sys.exit(1)
' "$name"
}

# Launch a fixed (non-template) session file. If a session with its baked
# session_name is already running, focus that instead of relaunching.
launch_session_file() {
  local file="$1"
  local name
  name="$(extract_session_name_from_file "$file")"
  if [[ -n "$name" ]] && session_is_running "$name"; then
    cmd_switch "$name"
    return 0
  fi
  if ! apply_session_file "$file" "${name:-}" "$HOME"; then
    pause_overlay
    exit 1
  fi
  [[ -n "$name" ]] && echo "$name"
}

cmd_list() {
  local tsv
  tsv="$(list_sessions_tsv)"
  if [[ -z "$tsv" ]]; then
    return 0
  fi
  HOME="$HOME" python3 -c '
import os, sys
home = os.environ.get("HOME", "")
items = []
for line in sys.stdin:
    line = line.rstrip("\n")
    if not line:
        continue
    parts = line.split("\t")
    if len(parts) < 5:
        continue
    name, cwd, _launch, focused, _last = parts[0], parts[1], parts[2], parts[3], parts[4]
    items.append((name, cwd, focused == "1"))
if not items:
    sys.exit(0)
name_w = max(len(n) for n, _, _ in items)
for name, cwd, focused in items:
    if home and cwd.startswith(home):
        cwd = "~" + cwd[len(home):]
    marker = "*" if focused else " "
    print(f"{marker} {name:<{name_w}}  {cwd}")
' <<<"$tsv"
}

cmd_switch() {
  local name="$1"
  local err
  if err="$(kitty @ --to "$socket" focus-window --match "var:session_name=$name" 2>&1 >/dev/null)"; then
    return 0
  fi
  if [[ "$err" == *"No matching windows"* ]]; then
    echo "ks: no session named '$name'" >&2
  else
    echo "ks: ${err:-failed to focus session \'$name\'}" >&2
  fi
  exit 1
}

cmd_kill_all() {
  local ids
  if ! ids="$(kitty @ --to "$socket" ls | python3 -c '
import json, sys
data = json.load(sys.stdin)
focused_os = None
for os_win in data:
    if os_win.get("is_focused"):
        focused_os = os_win.get("id")
        break
if focused_os is None:
    sys.stderr.write("ks: could not identify the focused kitty OS window\n")
    sys.exit(2)
for os_win in data:
    if os_win.get("id") == focused_os:
        continue
    if not any((w.get("user_vars") or {}).get("session_name")
               for tab in os_win.get("tabs", [])
               for w in tab.get("windows", [])):
        continue
    for tab in os_win.get("tabs", []):
        for w in tab.get("windows", []):
            wid = w.get("id")
            if wid is not None:
                print(wid)
')"; then
    exit 1
  fi
  if [[ -z "$ids" ]]; then
    echo "ks: no other sessions to kill" >&2
    return 0
  fi
  local wid count=0
  while IFS= read -r wid; do
    [[ -z "$wid" ]] && continue
    kitty @ --to "$socket" close-window --match "id:$wid" >/dev/null 2>&1 || true
    count=$((count + 1))
  done <<<"$ids"
  echo "ks: closed $count session window(s)" >&2
}

kill_session_by_name() {
  local name="$1"
  local ids
  ids="$(kitty @ --to "$socket" ls | python3 -c '
import json, sys
target = sys.argv[1]
data = json.load(sys.stdin)
for os_win in data:
    win_ids = []
    found = False
    for tab in os_win.get("tabs", []):
        for w in tab.get("windows", []):
            wid = w.get("id")
            if wid is not None:
                win_ids.append(str(wid))
            if (w.get("user_vars") or {}).get("session_name") == target:
                found = True
    if found:
        for wid in win_ids:
            print(wid)
        break
' "$name")"
  if [[ -z "$ids" ]]; then
    return 1
  fi
  local wid
  while IFS= read -r wid; do
    [[ -z "$wid" ]] && continue
    kitty @ --to "$socket" close-window --match "id:$wid" >/dev/null 2>&1 || true
  done <<<"$ids"
  return 0
}

cmd_kill() {
  local name="$1"
  if ! kill_session_by_name "$name"; then
    echo "ks: no session named '$name'" >&2
    exit 1
  fi
}

cmd_pick_session() {
  require_fzf
  local tsv display chosen name fzf_rc tsv_rc
  set +e
  tsv="$(list_sessions_tsv)"
  tsv_rc=$?
  set -e
  if [[ $tsv_rc -ne 0 ]]; then
    echo "ks: failed to query kitty sessions (rc=$tsv_rc)" >&2
    pause_overlay
    return 1
  fi
  if [[ -z "$tsv" ]]; then
    echo "ks: no active sessions" >&2
    pause_overlay
    return 0
  fi
  display="$(HOME="$HOME" python3 -c '
import os, sys
home = os.environ.get("HOME", "")
items = []
for line in sys.stdin:
    line = line.rstrip("\n")
    if not line:
        continue
    parts = line.split("\t")
    if len(parts) < 5:
        continue
    name, cwd, focused, last = parts[0], parts[1], parts[3] == "1", float(parts[4] or 0)
    items.append((name, cwd, focused, last))
if not items:
    sys.exit(0)
items.sort(key=lambda x: (x[2], x[3]))
name_w = max(len(n) for n, _, _, _ in items)
for name, cwd, _, _ in items:
    disp = cwd
    if home and disp.startswith(home):
        disp = "~" + disp[len(home):]
    print(f"{name}\t{name:<{name_w}}  {disp}")
' <<<"$tsv")"

  set +e
  chosen="$(printf "%s\n" "$display" | fzf --ansi --reverse --no-multi --height=40% \
    --with-nth=2 --delimiter=$'\t' --prompt='session > ' \
    --header='Enter: switch • Esc: cancel')"
  fzf_rc=$?
  set -e
  if [[ $fzf_rc -ne 0 || -z "$chosen" ]]; then
    return 0
  fi
  name="$(printf "%s" "$chosen" | cut -f1)"
  cmd_switch "$name"
}

cmd_pick_kill() {
  require_fzf
  local tsv display chosen fzf_rc tsv_rc
  set +e
  tsv="$(list_sessions_tsv)"
  tsv_rc=$?
  set -e
  if [[ $tsv_rc -ne 0 ]]; then
    echo "ks: failed to query kitty sessions (rc=$tsv_rc)" >&2
    pause_overlay
    return 1
  fi
  if [[ -z "$tsv" ]]; then
    echo "ks: no active sessions" >&2
    pause_overlay
    return 0
  fi
  display="$(HOME="$HOME" python3 -c '
import os, sys
home = os.environ.get("HOME", "")
items = []
for line in sys.stdin:
    line = line.rstrip("\n")
    if not line:
        continue
    parts = line.split("\t")
    if len(parts) < 5:
        continue
    name, cwd, focused, last = parts[0], parts[1], parts[3] == "1", float(parts[4] or 0)
    items.append((name, cwd, focused, last))
if not items:
    sys.exit(0)
items.sort(key=lambda x: (x[2], x[3]))
name_w = max(len(n) for n, _, _, _ in items)
for name, cwd, _, _ in items:
    disp = cwd
    if home and disp.startswith(home):
        disp = "~" + disp[len(home):]
    print(f"{name}\t{name:<{name_w}}  {disp}")
' <<<"$tsv")"

  set +e
  chosen="$(printf "%s\n" "$display" | fzf --ansi --reverse --multi --height=40% \
    --with-nth=2 --delimiter=$'\t' --prompt='kill > ' \
    --header='Tab: select • Enter: kill • Esc: cancel')"
  fzf_rc=$?
  set -e
  if [[ $fzf_rc -ne 0 || -z "$chosen" ]]; then
    return 0
  fi
  local name killed=0
  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    name="${line%%$'\t'*}"
    if kill_session_by_name "$name"; then
      killed=$((killed + 1))
    fi
  done <<<"$chosen"
  echo "ks: killed $killed session(s)" >&2
}

cmd_pick_new() {
  require_fzf
  if [[ -z "${KS_LOCATIONS:-}" ]]; then
    cat >&2 <<'EOF'
ks: KS_LOCATIONS is not set.
Example: export KS_LOCATIONS="$HOME/projects:$HOME/.config"
EOF
    pause_overlay
    exit 1
  fi

  local display chosen kind selector fzf_rc sub_rc sessions_dir
  sessions_dir="${KS_SESSIONS_DIR:-$HOME/.config/kitty/sessions}"

  set +e
  display="$(kitty @ --to "$socket" ls | \
    KS_LOCATIONS="$KS_LOCATIONS" KS_SESSIONS_DIR="$sessions_dir" HOME="$HOME" python3 -c '
import json, os, re, sys

def strip_private(p):
    return p[len("/private"):] if p.startswith("/private/") else p

home = os.environ.get("HOME", "")
locs = [os.path.expanduser(p) for p in os.environ.get("KS_LOCATIONS", "").split(":") if p]
sessions_dir = os.environ.get("KS_SESSIONS_DIR", "")

try:
    data = json.load(sys.stdin)
except (json.JSONDecodeError, ValueError):
    data = []

active_paths = set()
active_names = set()
for os_win in data:
    for tab in os_win.get("tabs", []):
        for w in tab.get("windows", []):
            uv = w.get("user_vars") or {}
            name = uv.get("session_name")
            if not name:
                continue
            active_names.add(name)
            fg = w.get("foreground_processes") or []
            cwd = (fg[0].get("cwd") if fg else None) or w.get("cwd", "")
            active_paths.add(strip_private(uv.get("session_path") or cwd))

# Directory candidates (under KS_LOCATIONS, not already a running session).
seen = set()
dirs = []
for loc in locs:
    if not os.path.isdir(loc):
        continue
    try:
        names = sorted(os.listdir(loc))
    except OSError:
        continue
    for n in names:
        if n.startswith("."):
            continue
        full = os.path.join(loc, n)
        if not os.path.isdir(full):
            continue
        try:
            abs_full = strip_private(os.path.realpath(full))
        except OSError:
            abs_full = strip_private(full)
        if abs_full in active_paths or abs_full in seen:
            continue
        seen.add(abs_full)
        dirs.append((os.path.basename(abs_full), abs_full))
dirs.sort(key=lambda x: (x[0].lower(), x[1]))

# Session-file candidates (sessions_dir/*.kitty-session, excluding template).
sessions = []
if sessions_dir and os.path.isdir(sessions_dir):
    try:
        for n in sorted(os.listdir(sessions_dir)):
            if n.startswith(".") or not n.endswith(".kitty-session"):
                continue
            if n == "template.kitty-session":
                continue
            full = os.path.join(sessions_dir, n)
            baked = None
            try:
                with open(full) as f:
                    for raw in f:
                        s = raw.strip()
                        if not s or s.startswith("#"):
                            continue
                        if s.split()[0] == "launch":
                            m = re.search(r"--var=session_name=(\S+)", s)
                            if m:
                                baked = m.group(1)
                            break
            except OSError:
                continue
            label = n[: -len(".kitty-session")]
            running = bool(baked) and baked in active_names
            sessions.append((label, full, running))
    except OSError:
        pass
sessions.sort(key=lambda x: x[0].lower())

if not dirs and not sessions:
    sys.exit(0)

label_w = max([len(s[0]) for s in sessions] + [len(d[0]) for d in dirs] + [0])

# Emit sessions first (they are typically fewer and more specific).
for label, full, running in sessions:
    suffix = "  (running)" if running else ""
    print(f"session\t{full}\t[session] {label:<{label_w}}{suffix}")

for label, abs_full in dirs:
    d = abs_full
    if home and d.startswith(home):
        d = "~" + d[len(home):]
    print(f"dir\t{abs_full}\t[dir]     {label:<{label_w}}  {d}")
')"
  sub_rc=$?
  set -e

  if [[ $sub_rc -ne 0 ]]; then
    echo "ks: failed to query kitty sessions (rc=$sub_rc)" >&2
    pause_overlay
    return 1
  fi

  if [[ -z "$display" ]]; then
    echo "ks: no available directories or session files" >&2
    pause_overlay
    return 0
  fi

  set +e
  chosen="$(printf "%s\n" "$display" | fzf --ansi --reverse --no-multi --height=40% \
    --with-nth=3 --delimiter=$'\t' --prompt='new > ' \
    --header='Enter: open • Esc: cancel')"
  fzf_rc=$?
  set -e
  if [[ $fzf_rc -ne 0 || -z "$chosen" ]]; then
    return 0
  fi
  kind="$(printf "%s" "$chosen" | cut -f1)"
  selector="$(printf "%s" "$chosen" | cut -f2)"
  case "$kind" in
    session) launch_session_file "$selector" ;;
    dir)     create_session "$selector" ;;
    *)
      echo "ks: unknown selection type: $kind" >&2
      pause_overlay
      return 1
      ;;
  esac
}

# --- Dispatch ---

if [[ $# -lt 1 ]]; then
  usage >&2
  exit 1
fi

case "$1" in
  -h|--help) usage; exit 0 ;;
  -l|--list) cmd_list; exit 0 ;;
  -s|--switch)
    if [[ $# -lt 2 || -z "$2" ]]; then
      echo "ks: -s requires a session name" >&2
      exit 1
    fi
    cmd_switch "$2"
    exit 0
    ;;
  -k|--kill)
    if [[ $# -lt 2 || -z "$2" ]]; then
      cmd_pick_kill
    elif [[ "$2" == "--all" || "$2" == "-a" ]]; then
      cmd_kill_all
    else
      cmd_kill "$2"
    fi
    exit 0
    ;;
  -i|--interactive) cmd_pick_session; exit 0 ;;
  -n|--new) cmd_pick_new; exit 0 ;;
esac

target="$1"
if [[ ! -d "$target" ]]; then
  echo "ks: not a directory: $target" >&2
  exit 1
fi
abs_path="$(cd "$target" && pwd)"
create_session "$abs_path"
