#!/usr/bin/env python3
"""ks - kitty session helper.
Env vars:
  KS_LOCATIONS      Colon-separated parent dirs for `-n` candidate enumeration.
  KS_TEMPLATE       Path to session-file template (default: ~/.config/kitty/sessions/template.kitty-session).
  KS_SESSIONS_DIR   Directory of *.kitty-session files for `-n` (default: ~/.config/kitty/sessions).
  KS_PICKER         Interactive picker: `fuzzel`, `dmenu`, or `fzf`. Unset
                    prefers fuzzel (Wayland), then dmenu, then fzf. fuzzel and
                    dmenu are single-select (the `-k`/`-n` multi-select is
                    fzf-only).
"""

from __future__ import annotations

import glob
import json
import os
import re
import shlex
import shutil
import socket as _socket
import subprocess
import sys
from dataclasses import dataclass


HOME = os.environ.get("HOME", "")

# Pinned protocol version for direct unix-socket RC. Must be <= installed kitty
# version. 0.14.2 is conservative — modern kittys (≥0.14.2, which is years old)
# accept it; older kittys would reject with a clear error.
KITTY_RC_VERSION = [0, 14, 2]


def resolve_socket() -> str:
    listen = os.environ.get("KITTY_LISTEN_ON")
    if listen:
        return listen
    def mtime(p: str) -> float:
        try:
            return os.path.getmtime(p)
        except OSError:  # socket vanished between glob and stat
            return 0.0

    candidates = sorted(glob.glob("/tmp/mykitty-*"), key=mtime, reverse=True)
    if not candidates:
        sys.stderr.write(
            "ks: no kitty socket found (is kitty running with listen_on?)\n"
        )
        sys.exit(1)
    return "unix:" + candidates[0]


SOCKET = resolve_socket()
SOCKET_PATH = SOCKET[len("unix:") :] if SOCKET.startswith("unix:") else ""


# --- low-level helpers ---


def strip_private(p: str) -> str:
    return p[len("/private") :] if p.startswith("/private/") else p


def _args_to_payload(args: tuple) -> tuple[str, dict]:
    """Parse CLI-style `kitty @` args into (cmd, payload) for the RC protocol.

    Handles the subset ks emits: `--key=value`, `--key value`, repeated `--var`,
    and trailing positional args (which become the launch process `args`).
    Like the real `kitty @` CLI, the first positional ends flag parsing — a
    launched program's own flags (e.g. `launch irssi --profile x`) must not be
    mistaken for RC fields.
    """
    if not args:
        raise ValueError("no args")
    cmd = args[0].replace("-", "_")
    payload: dict = {}
    positional: list[str] = []
    i = 1
    while i < len(args):
        a = args[i]
        if a == "--":
            positional.extend(args[i + 1 :])
            break
        if not positional and a.startswith("--"):
            key, eq, val = a[2:].partition("=")
            key = key.replace("-", "_")
            if not eq:
                if i + 1 < len(args) and not args[i + 1].startswith("--"):
                    val = args[i + 1]
                    i += 1
                else:
                    val = True
            if key == "var":
                payload.setdefault("var", []).append(val)
            else:
                payload[key] = val
        else:
            positional.append(a)
        i += 1
    if positional:
        payload["args"] = positional
    return cmd, payload


class KittySocketUnavailable(Exception):
    """The RC fast path failed before the command reached kitty (connect/send).
    Falling back to the `kitty @` CLI cannot double-execute the command."""


def kitty_at(*args: str, check: bool = True) -> str:
    """Run a `kitty @` command. Uses the direct unix-socket RC path (~25ms
    faster than spawning the CLI). Falls back to the `kitty @` subprocess only
    when the command provably never reached kitty (unparseable args, connect/
    send failure). A post-send failure must NOT fall back: a side-effectful
    command like `launch` may already have executed."""
    if SOCKET_PATH:
        resp = None
        try:
            cmd_name, payload = _args_to_payload(args)
            req: dict = {"cmd": cmd_name}
            if payload:
                req["payload"] = payload
            resp = _socket_rc(req)
        except (ValueError, KittySocketUnavailable):
            resp = None
        except RuntimeError as e:
            if check:
                sys.stderr.write("ks: kitty @ " + " ".join(args) + "\n")
                sys.stderr.write(f"ks: {e}\n")
                sys.exit(1)
            return ""
        if resp is not None:
            if not resp.get("ok"):
                if check:
                    sys.stderr.write("ks: kitty @ " + " ".join(args) + "\n")
                    sys.stderr.write("ks: " + str(resp.get("error", "unknown")) + "\n")
                    sys.exit(1)
                return ""
            data = resp.get("data")
            if data is None:
                return ""
            return data if isinstance(data, str) else str(data)
    cmd = ["kitty", "@", "--to", SOCKET, *args]
    res = subprocess.run(cmd, capture_output=True, text=True)
    if res.returncode != 0:
        if check:
            sys.stderr.write("ks: " + " ".join(shlex.quote(a) for a in cmd) + "\n")
            sys.stderr.write("ks: " + res.stderr.strip() + "\n")
            sys.exit(1)
        return ""
    return res.stdout.strip()


def _socket_rc(payload: dict, timeout: float = 5.0) -> dict:
    """Send one command directly over kitty's RC unix socket. ~30× faster than
    spawning `kitty @` because we skip a full kitty interpreter startup.

    Raises KittySocketUnavailable if the command was never delivered (safe to
    retry via the CLI), RuntimeError if it was delivered but the response is
    missing/malformed (the command may have executed — do not retry)."""
    payload.setdefault("version", KITTY_RC_VERSION)
    payload.setdefault("no_response", False)
    msg = b"\x1bP@kitty-cmd" + json.dumps(payload).encode() + b"\x1b\\"
    s = _socket.socket(_socket.AF_UNIX, _socket.SOCK_STREAM)
    s.settimeout(timeout)
    buf = b""
    try:
        try:
            s.connect(SOCKET_PATH)
            # A partial send leaves the DCS frame unterminated, which kitty
            # discards — so send failures cannot have executed the command.
            s.sendall(msg)
        except OSError as e:
            raise KittySocketUnavailable(str(e)) from e
        try:
            while True:
                chunk = s.recv(65536)
                if not chunk:
                    break
                buf += chunk
                if buf.endswith(b"\x1b\\"):
                    break
        except OSError as e:
            raise RuntimeError(f"error reading kitty response: {e}") from e
    finally:
        s.close()
    if not buf.startswith(b"\x1bP@kitty-cmd") or not buf.endswith(b"\x1b\\"):
        raise RuntimeError("unexpected response framing from kitty socket")
    try:
        return json.loads(buf[len(b"\x1bP@kitty-cmd") : -2])
    except ValueError as e:
        raise RuntimeError(f"invalid JSON in kitty response: {e}") from e


def kitty_ls() -> list:
    # Fast path: direct unix-socket RC. Falls back to `kitty @ ls` subprocess
    # only when listen_on isn't a unix socket (e.g. tcp:) or the socket call
    # fails for any reason.
    if SOCKET_PATH:
        try:
            resp = _socket_rc({"cmd": "ls"})
        except (KittySocketUnavailable, RuntimeError):
            # ls is read-only, so retrying via the CLI below is harmless.
            resp = None
        if resp is not None:
            if not resp.get("ok"):
                sys.stderr.write(
                    f"ks: kitty RC error: {resp.get('error', 'unknown')}\n"
                )
                sys.exit(1)
            data = resp.get("data")
            if isinstance(data, str):
                try:
                    return json.loads(data)
                except (json.JSONDecodeError, ValueError):
                    return []
            if isinstance(data, list):
                return data
            return []
    raw = kitty_at("ls")
    try:
        return json.loads(raw)
    except (json.JSONDecodeError, ValueError):
        return []


# --- domain ---


@dataclass
class SessionRow:
    name: str
    cwd: str
    focused: bool
    last_focused_at: float


def _os_window_for_session(name: str, data: list) -> dict | None:
    """The OS window hosting session `name` — i.e. containing any window tagged
    with it. ks's model is one session == one OS window, so the first match
    wins. With every ks window carrying the session_name tag, this is the single
    source of truth for session lookup (no state file)."""
    for os_win in data:
        for tab in os_win.get("tabs", []):
            for w in tab.get("windows", []):
                if _window_session_name(w) == name:
                    return os_win
    return None


def _window_session_name(w: dict) -> str:
    """Read a session name from kitty's built-in top-level field first, then
    fall back to the user_var we set ourselves. Either is good enough to tag
    the OS window as a session."""
    return w.get("session_name") or (w.get("user_vars") or {}).get("session_name") or ""


def _builtin_session_name_for_os_window(os_win: dict) -> str:
    """First non-empty session_name found anywhere in this OS window. Used as
    fallback detection for OS windows started via `startup_session` /
    `kitty --session`, where the built-in field auto-propagates to every
    window."""
    for tab in os_win.get("tabs", []):
        for w in tab.get("windows", []):
            n = _window_session_name(w)
            if n:
                return n
    return ""


def find_current_session_name(data: list) -> str | None:
    """The session you're currently "in" — the most-recently-focused tagged
    window in the focused OS window."""
    focused_os: dict | None = None
    for os_win in data:
        if os_win.get("is_focused"):
            focused_os = os_win
            break
    if focused_os is None:
        return None
    best_name: str | None = None
    best_t = -1.0
    for tab in focused_os.get("tabs", []):
        for w in tab.get("windows", []):
            name = _window_session_name(w)
            if not name:
                continue
            t = float(w.get("last_focused_at") or 0)
            if t > best_t:
                best_name, best_t = name, t
    return best_name


def _build_row_for_os_window(os_win: dict, name: str) -> SessionRow:
    """Collapse an OS window into a SessionRow.

    The displayed cwd is intentionally stable, not "wherever the user last cd'd
    to" (a most-recently-focused rep would show whatever transient window grabbed
    focus last — including the overlay running `ks -i`). We use the immutable
    session_path user_var set at launch, falling back to the cwd of the
    *earliest* window carrying the session_name tag (the original launch window).
    """
    os_focused = bool(os_win.get("is_focused"))
    last_t = 0.0
    is_session_focused = False

    rep_cwd = ""
    rep_path = ""
    rep_id: int | None = None

    for tab in os_win.get("tabs", []):
        tab_focused = bool(tab.get("is_focused"))
        for w in tab.get("windows", []):
            t = float(w.get("last_focused_at") or 0)
            if t > last_t:
                last_t = t
            if os_focused and tab_focused and bool(w.get("is_focused")):
                is_session_focused = True
            if _window_session_name(w) == name:
                wid = w.get("id")
                if isinstance(wid, int) and (rep_id is None or wid < rep_id):
                    fg = w.get("foreground_processes") or []
                    rep_cwd = (
                        (fg[0].get("cwd") if fg else None) or w.get("cwd", "") or ""
                    )
                    rep_path = (w.get("user_vars") or {}).get("session_path") or ""
                    rep_id = wid

    cwd = strip_private(rep_path or rep_cwd)
    return SessionRow(
        name=name,
        cwd=cwd,
        focused=is_session_focused,
        last_focused_at=last_t,
    )


def list_sessions(data: list | None = None) -> list[SessionRow]:
    """Every OS window carrying a session_name tag becomes one SessionRow,
    derived entirely from live `kitty @ ls`. Covers both ks sessions (all
    windows now tagged) and kitty-native ones (startup_session / --session)."""
    if data is None:
        data = kitty_ls()
    rows: list[SessionRow] = []
    for os_win in data:
        name = _builtin_session_name_for_os_window(os_win)
        if not name:
            continue
        rows.append(_build_row_for_os_window(os_win, name))
    return sorted(
        rows,
        key=lambda r: (-int(r.focused), -r.last_focused_at, r.name),
    )


def extract_session_name_from_file(path: str) -> str | None:
    """Return the --var=session_name=... value from the first `launch` directive
    that carries one, or None. The template contract is "at least one launch
    line MUST carry the var", so keep scanning past launches that don't.
    """
    try:
        with open(path) as f:
            for raw in f:
                line = raw.strip()
                if not line or line.startswith("#"):
                    continue
                if line.split()[0] != "launch":
                    continue
                try:
                    tokens = shlex.split(line)
                except ValueError:
                    continue
                for a in tokens[1:]:
                    m = re.match(r"--var=session_name=(.+)$", a)
                    if m:
                        return m.group(1)
    except OSError:
        return None
    return None


def session_is_running(name: str) -> bool:
    return _os_window_for_session(name, kitty_ls()) is not None


def apply_session_file(path: str, session_name: str, initial_cwd: str) -> int:
    """Render and replay a (possibly templated) kitty session file as `kitty @`
    calls against the running kitty over SOCKET. Returns 0 on success, 1 on error.
    """
    try:
        with open(path) as f:
            text = f.read()
    except OSError as e:
        sys.stderr.write(f"ks: cannot read session file: {path}: {e}\n")
        return 1

    text = text.replace("${KS_CWD}", initial_cwd).replace(
        "${KS_SESSION_NAME}", session_name
    )

    cwd = initial_cwd
    file_dir = os.path.dirname(os.path.abspath(path))
    os_window_title = session_name or os.path.basename(path)
    first_launch_done = False
    last_window_id: str | None = None
    focused_window_id: str | None = None
    # `launch --match` matches TABS: `id:` means a *tab* id (window ids are only
    # a fallback), and kitty 0.47 rejects window_id: for launch. So each tab's
    # first window gets a unique session_tab user var — an unambiguous anchor
    # for follow-up launches into the session.
    current_tab_match: str | None = None

    def new_tab_anchor() -> tuple[str, str]:
        """A fresh per-tab anchor: (--var launch arg, match expression)."""
        tag = "session_tab=" + os.urandom(3).hex()
        return "--var=" + tag, "var:" + tag

    # Tag EVERY window we create with the session name (not just the first), so
    # the whole OS window is resolvable from live `kitty @ ls` alone — this is
    # what lets ks run without a state file.
    session_vars = ["--var=session_name=" + session_name] if session_name else []
    pending_tab: str | None = None  # new_tab seen, its first launch not yet emitted

    def launch_tab(title: str, launch_rest: list[str]) -> bool:
        nonlocal last_window_id, current_tab_match
        if not current_tab_match:
            sys.stderr.write("ks: new_tab has no anchor window to target\n")
            return False
        tab_var, tab_match = new_tab_anchor()
        args = [
            "launch",
            "--type=tab",
            "--match",
            current_tab_match,
            "--cwd=" + cwd,
            *session_vars,
            tab_var,
        ]
        if title:
            args.append("--tab-title=" + title)
        args += launch_rest
        wid = kitty_at(*args)
        if wid.isdigit():
            last_window_id = wid
        current_tab_match = tab_match
        return True

    for raw in text.splitlines():
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        parts = shlex.split(line)
        directive, rest = parts[0], parts[1:]

        if directive == "cd":
            target = rest[0] if rest else cwd
            target = os.path.expanduser(target)
            cwd = (
                target
                if os.path.isabs(target)
                # Native kitty resolves relative cd paths against the session
                # file's location, not the previous cwd.
                else os.path.abspath(os.path.join(file_dir, target))
            )
        elif directive == "os_window_title":
            os_window_title = " ".join(rest)
        elif directive == "launch":
            if not first_launch_done:
                tab_var, tab_match = new_tab_anchor()
                args = [
                    "launch",
                    "--type=os-window",
                    "--cwd=" + cwd,
                    "--os-window-title=" + os_window_title,
                    *session_vars,
                    tab_var,
                ]
                if session_name:
                    # Stamp the session's launch dir on this and every later
                    # window so -l/-n show a stable dir even after the user
                    # cd's around or closes the original window.
                    args.append("--var=session_path=" + cwd)
                    session_vars.append("--var=session_path=" + cwd)
                if pending_tab:
                    args.append("--tab-title=" + pending_tab)
                args += rest
                wid = kitty_at(*args)
                if wid.isdigit():
                    last_window_id = wid
                current_tab_match = tab_match
            elif pending_tab is not None:
                if not launch_tab(pending_tab, rest):
                    return 1
            else:
                if not current_tab_match:
                    sys.stderr.write("ks: launch has no anchor window to target\n")
                    return 1
                wid = kitty_at(
                    "launch",
                    "--match",
                    current_tab_match,
                    "--cwd=" + cwd,
                    *session_vars,
                    *rest,
                )
                if wid.isdigit():
                    last_window_id = wid
            pending_tab = None
            first_launch_done = True
        elif directive == "new_tab":
            # Native kitty session semantics: new_tab opens a tab whose first
            # window comes from the NEXT launch line. Defer creating it so the
            # tab doesn't get an extra shell window alongside that launch.
            if pending_tab is not None and first_launch_done:
                # previous new_tab had no launch of its own: plain shell tab
                if not launch_tab(pending_tab, []):
                    return 1
            pending_tab = " ".join(rest)
        elif directive == "focus":
            focused_window_id = last_window_id
        elif directive == "focus_os_window":
            pass
        else:
            sys.stderr.write(
                f"ks: warning: unsupported session-file directive: {directive}\n"
            )

    if pending_tab is not None and first_launch_done:
        # trailing new_tab with no launch of its own: plain shell tab
        if not launch_tab(pending_tab, []):
            return 1

    if not first_launch_done:
        sys.stderr.write("ks: session file defined no launch directives\n")
        return 1

    if focused_window_id:
        kitty_at("focus-window", "--match", "id:" + focused_window_id)
    return 0


def create_session(abs_path: str) -> str:
    folder_name = os.path.basename(abs_path)
    uid = os.urandom(3).hex()
    session_name = f"{folder_name}-{uid}"
    template = os.environ.get("KS_TEMPLATE") or os.path.join(
        HOME, ".config/kitty/sessions/template.kitty-session"
    )
    if not os.access(template, os.R_OK):
        sys.stderr.write(f"ks: template not found or unreadable: {template}\n")
        sys.stderr.write(
            "ks: set KS_TEMPLATE to override, or create the default template\n"
        )
        pause_overlay()
        sys.exit(1)
    if apply_session_file(template, session_name, abs_path) != 0:
        pause_overlay()
        sys.exit(1)
    return session_name


def launch_session_file(path: str) -> None:
    name = extract_session_name_from_file(path)
    if name and session_is_running(name):
        cmd_switch(name)
        return
    if apply_session_file(path, name or "", HOME) != 0:
        pause_overlay()
        sys.exit(1)
    if name:
        print(name)


def kill_session_by_name(name: str, data: list | None = None) -> bool:
    """Close the entire OS window hosting session `name` (ks's model: one
    session == one OS window). Returns False if no such session is running."""
    if data is None:
        data = kitty_ls()
    os_win = _os_window_for_session(name, data)
    if os_win is None:
        return False
    ids = [
        w.get("id")
        for tab in os_win.get("tabs", [])
        for w in tab.get("windows", [])
        if w.get("id") is not None
    ]
    if ids:
        kitty_at(
            "close-window",
            "--match",
            " or ".join(f"id:{w}" for w in ids),
            check=False,
        )
    return True


# --- display + picker ---


def display_cwd(p: str) -> str:
    if HOME and (p == HOME or p.startswith(HOME + "/")):
        return "~" + p[len(HOME) :]
    return p


def session_items(rows: list[SessionRow]) -> list[tuple[str, str]]:
    """(value, display) pairs shared by -i/-k: value is the session name, display
    is "name  cwd". The picker layer shows `display` and hands back `value`."""
    name_w = max(len(r.name) for r in rows)
    return [(r.name, f"{r.name:<{name_w}}  {display_cwd(r.cwd)}") for r in rows]


def pause_overlay() -> None:
    if not sys.stderr.isatty():
        return
    try:
        sys.stderr.write("ks: press any key to close...")
        sys.stderr.flush()
        with open("/dev/tty", "rb", buffering=0) as tty:
            tty.read(1)
        sys.stderr.write("\n")
    except OSError:
        pass


def load_fzf_env() -> None:
    """Populate FZF_DEFAULT_OPTS from ~/.config/zsh/fzf.sh if not already set.

    kitty launched from the Dock/Spotlight doesn't inherit zsh exports, so when
    `ks` is triggered by an overlay keybinding the FZF theme env isn't in the
    environment. The bash launcher used to source fzf.sh — we now do the same
    inline (single-quoted multi-line and double-quoted single-line `export`s),
    and only for the picker paths that actually run fzf.
    """
    if os.environ.get("FZF_DEFAULT_OPTS"):
        return
    path = os.path.join(HOME, ".config/zsh/fzf.sh")
    try:
        with open(path) as f:
            text = f.read()
    except OSError:
        return
    m = re.search(
        r"^[ \t]*export[ \t]+FZF_DEFAULT_OPTS=(['\"])(.*?)\1",
        text,
        re.DOTALL | re.MULTILINE,
    )
    if m:
        os.environ["FZF_DEFAULT_OPTS"] = m.group(2)


def resolve_picker() -> str:
    """Which interactive picker to use. Honors KS_PICKER (fuzzel|dmenu|fzf) when
    it names an installed binary; otherwise auto-selects, preferring fuzzel (the
    Wayland GUI picker), then dmenu (X11), then fzf. Returns "" if none exist."""
    order = []
    choice = (os.environ.get("KS_PICKER") or "").strip().lower()
    if choice in ("fuzzel", "dmenu", "fzf"):
        order.append(choice)
    for p in ("fuzzel", "dmenu", "fzf"):
        if p not in order:
            order.append(p)
    for p in order:
        if shutil.which(p):
            return p
    return ""


def pick(
    items: list[tuple],
    *,
    prompt: str,
    header: str,
    multi: bool,
) -> list | None:
    """Run the resolved picker over (value, display) pairs. Returns the list of
    selected `value`s, or None on cancel. dmenu is single-select regardless of
    `multi`; fzf honors it."""
    picker = resolve_picker()
    if not picker:
        sys.stderr.write("ks: no picker found in PATH (install fuzzel, dmenu, or fzf)\n")
        pause_overlay()
        sys.exit(1)
    if picker == "fzf":
        load_fzf_env()
        return _pick_fzf(items, prompt=prompt, header=header, multi=multi)
    if picker == "fuzzel":
        return _pick_fuzzel(items, prompt=prompt)
    return _pick_dmenu(items, prompt=prompt)


def _pick_fzf(
    items: list[tuple],
    *,
    prompt: str,
    header: str,
    multi: bool,
) -> list | None:
    # Carry the item index (not the value) in hidden field 1 so displays with
    # tabs or duplicate text can never confuse the read-back. fzf shows field 2.
    lines = [f"{i}\t{display}" for i, (_, display) in enumerate(items)]
    cmd = [
        "fzf",
        "--ansi",
        "--reverse",
        "--height=40%",
        "--with-nth=2",
        "--delimiter=\t",
        f"--prompt={prompt}",
        f"--header={header}",
        "--multi" if multi else "--no-multi",
    ]
    res = subprocess.run(cmd, input="\n".join(lines), capture_output=True, text=True)
    # fzf exit: 0 = match, 1 = no match, 2 = error, 130 = ctrl-c/esc
    if res.returncode != 0:
        return None
    out = res.stdout.strip("\n")
    if not out:
        return None
    values = []
    for line in out.split("\n"):
        idx = line.split("\t", 1)[0]
        if idx.isdigit() and int(idx) < len(items):
            values.append(items[int(idx)][0])
    return values or None


def _pick_fuzzel(items: list[tuple], *, prompt: str) -> list | None:
    """fuzzel --dmenu is a Wayland-native dmenu replacement. --index makes it
    echo the chosen row's index instead of its text, so displays with duplicate
    or tab-laden text can't confuse the read-back. Single-select (GUI overlay),
    like dmenu; -k/-n multi-select still needs fzf."""
    displays = [display for _, display in items]
    # -d: dmenu mode. --index: print the selected row index. -l 20: list height.
    cmd = ["fuzzel", "--dmenu", "--index", "-l", "20", "-p", prompt.strip() + " "]
    res = subprocess.run(cmd, input="\n".join(displays), capture_output=True, text=True)
    if res.returncode != 0:
        return None
    out = res.stdout.strip("\n")
    if not out.isdigit() or int(out) >= len(items):
        return None
    return [items[int(out)][0]]


def _pick_dmenu(items: list[tuple], *, prompt: str) -> list | None:
    """dmenu shows exactly the lines it's fed and echoes the chosen one, so we
    map display -> value ourselves. Single-select only; no --with-nth/--header,
    so alignment padding is best-effort under dmenu's font."""
    by_display: dict[str, object] = {}
    displays: list[str] = []
    for value, display in items:
        by_display[display] = value
        displays.append(display)
    # -i: case-insensitive. -l 20: vertical list rather than a single-line bar.
    cmd = ["dmenu", "-i", "-l", "20", "-p", prompt.strip()]
    res = subprocess.run(cmd, input="\n".join(displays), capture_output=True, text=True)
    if res.returncode != 0:
        return None
    out = res.stdout.strip("\n")
    # dmenu echoes typed text when it matches no row; only act on a real row.
    if out not in by_display:
        return None
    return [by_display[out]]


# --- commands ---


def cmd_list() -> None:
    data = kitty_ls()
    rows = list_sessions(data)
    if not rows:
        return
    current = find_current_session_name(data)
    name_w = max(len(r.name) for r in rows)
    for r in rows:
        marker = "*" if r.name == current else " "
        print(f"{marker} {r.name:<{name_w}}  {display_cwd(r.cwd)}")


def cmd_switch(name: str) -> None:
    data = kitty_ls()
    os_win = _os_window_for_session(name, data)
    if os_win is None:
        sys.stderr.write(f"ks: no session named '{name}'\n")
        sys.exit(1)

    # Pick a window to focus inside the target OS window: prefer the active
    # tab's active window so focus lands where the user left it.
    target_wid: int | None = None
    for tab in os_win.get("tabs", []):
        if not tab.get("is_active"):
            continue
        for w in tab.get("windows", []):
            if w.get("is_active"):
                target_wid = w.get("id")
                break
        if target_wid is None:
            for w in tab.get("windows", []):
                target_wid = w.get("id")
                break
        break
    if target_wid is None:
        for tab in os_win.get("tabs", []):
            for w in tab.get("windows", []):
                target_wid = w.get("id")
                break
            if target_wid is not None:
                break

    if target_wid is None:
        sys.stderr.write(f"ks: session '{name}' has no windows to focus\n")
        sys.exit(1)

    kitty_at("focus-window", "--match", f"id:{target_wid}")


def cmd_kill(names: list[str]) -> None:
    missing = [n for n in names if not kill_session_by_name(n)]
    if missing:
        for n in missing:
            sys.stderr.write(f"ks: no session named '{n}'\n")
        sys.exit(1)


def cmd_kill_all() -> None:
    data = kitty_ls()
    focused_os: int | None = None
    for os_win in data:
        if os_win.get("is_focused"):
            focused_os = os_win.get("id")
            break
    if focused_os is None:
        sys.stderr.write("ks: could not identify the focused kitty OS window\n")
        sys.exit(2)

    ids: list[str] = []
    for os_win in data:
        if os_win.get("id") == focused_os:
            continue
        if not _builtin_session_name_for_os_window(os_win):
            continue
        for tab in os_win.get("tabs", []):
            for w in tab.get("windows", []):
                wid = w.get("id")
                if wid is not None:
                    ids.append(str(wid))

    if not ids:
        sys.stderr.write("ks: no other sessions to kill\n")
        return

    kitty_at(
        "close-window",
        "--match",
        " or ".join(f"id:{w}" for w in ids),
        check=False,
    )
    sys.stderr.write(f"ks: closed {len(ids)} session window(s)\n")


def cmd_pick_session() -> None:
    data = kitty_ls()
    rows = list_sessions(data)
    if not rows:
        sys.stderr.write("ks: no active sessions\n")
        pause_overlay()
        return
    # The overlay grabs focus, so kitty no longer reports any session window as
    # focused. To put the *previously* focused (= last visited) session at the
    # fzf cursor and the user's current session at the bottom, identify the
    # current session from the focused tab and rank it last.
    current_name = find_current_session_name(data)
    rows = sorted(
        rows,
        key=lambda r: (r.name == current_name, -r.last_focused_at),
    )
    chosen = pick(
        session_items(rows),
        prompt="session ❯ ",
        header="Enter: switch • Esc: cancel",
        multi=False,
    )
    if not chosen:
        return
    cmd_switch(chosen[0])


def cmd_pick_kill() -> None:
    data = kitty_ls()
    rows = list_sessions(data)
    if not rows:
        sys.stderr.write("ks: no active sessions\n")
        pause_overlay()
        return
    # Ascending: focused session lands at bottom of the fzf list — safer default
    # when the action is destructive.
    rows = sorted(rows, key=lambda r: (r.focused, r.last_focused_at))
    chosen = pick(
        session_items(rows),
        prompt="kill ❯ ",
        header="Tab: select • Enter: kill • Esc: cancel",
        multi=True,
    )
    if not chosen:
        return
    killed = 0
    for name in chosen:
        if kill_session_by_name(name, data=data):
            killed += 1
    sys.stderr.write(f"ks: killed {killed} session(s)\n")


def cmd_pick_new() -> None:
    locations = os.environ.get("KS_LOCATIONS", "")
    if not locations:
        sys.stderr.write(
            "ks: KS_LOCATIONS is not set.\n"
            'Example: export KS_LOCATIONS="$HOME/projects:$HOME/.config"\n'
        )
        pause_overlay()
        sys.exit(1)

    locs = [os.path.expanduser(p) for p in locations.split(":") if p]
    sessions_dir = os.environ.get("KS_SESSIONS_DIR") or os.path.join(
        HOME, ".config/kitty/sessions"
    )

    # Derive running-session names and launch dirs from list_sessions so this
    # matches every other code path: it sees kitty-native sessions (built-in
    # session_name field) too, and uses the stable session_path launch dir
    # rather than wherever a window happens to have cd'd to.
    rows = list_sessions()
    active_names = {r.name for r in rows}
    active_paths = {r.cwd for r in rows}

    # Directory candidates under KS_LOCATIONS. Dirs already hosting a session
    # stay listed (session names are unique, so the same dir can back several
    # sessions) — they just get an "(open)" hint.
    seen: set[str] = set()
    dirs: list[tuple[str, str, bool]] = []  # (label, abs_path, open)
    for loc in locs:
        if not os.path.isdir(loc):
            continue
        try:
            names = sorted(os.listdir(loc))
        except OSError:
            continue
        for n in names:
            if n.startswith("."):
                continue
            full = os.path.join(loc, n)
            if not os.path.isdir(full):
                continue
            try:
                abs_full = strip_private(os.path.realpath(full))
            except OSError:
                abs_full = strip_private(full)
            if abs_full in seen:
                continue
            seen.add(abs_full)
            dirs.append(
                (os.path.basename(abs_full), abs_full, abs_full in active_paths)
            )
    dirs.sort(key=lambda x: (x[0].lower(), x[1]))

    # Session-file candidates (sessions_dir/*.kitty-session, excluding template).
    sessions: list[tuple[str, str, bool]] = []  # (label, full_path, running)
    if sessions_dir and os.path.isdir(sessions_dir):
        try:
            entries = sorted(os.listdir(sessions_dir))
        except OSError:
            entries = []
        for n in entries:
            if n.startswith(".") or not n.endswith(".kitty-session"):
                continue
            if n == "template.kitty-session":
                continue
            full = os.path.join(sessions_dir, n)
            baked = extract_session_name_from_file(full)
            label = n[: -len(".kitty-session")]
            running = bool(baked) and baked in active_names
            sessions.append((label, full, running))
    sessions.sort(key=lambda x: x[0].lower())

    if not dirs and not sessions:
        sys.stderr.write("ks: no available directories or session files\n")
        pause_overlay()
        return

    label_w = max([len(s[0]) for s in sessions] + [len(d[0]) for d in dirs] + [0])

    # (value, display): value is a (kind, selector) pair the picker hands back.
    items: list[tuple] = []
    for label, full, running in sessions:
        suffix = "  (running)" if running else ""
        items.append((("session", full), f"[session] {label:<{label_w}}{suffix}"))
    for label, abs_full, is_open in dirs:
        suffix = "  (open)" if is_open else ""
        items.append(
            (
                ("dir", abs_full),
                f"[dir]     {label:<{label_w}}  {display_cwd(abs_full)}{suffix}",
            )
        )

    chosen = pick(
        items,
        prompt="new ❯ ",
        header="Tab: select • Enter: open • Esc: cancel",
        multi=True,
    )
    if not chosen:
        return
    for kind, selector in chosen:
        if kind == "session":
            launch_session_file(selector)
        elif kind == "dir":
            name = create_session(selector)
            print(name)
        else:
            sys.stderr.write(f"ks: unknown selection type: {kind}\n")
            pause_overlay()
            sys.exit(1)


# --- dispatch ---


USAGE = """Usage:
  ks <path> ...    Open a kitty OS window per path, tagged session_name=<folder>-<uid>.
  ks -l            List all active kitty sessions.
  ks -s <name>     Switch focus to the session with the given name.
  ks -k            Interactive picker over active sessions; kill on Enter.
  ks -k <name> ... Close the named session(s) (closes their OS windows).
  ks -k --all      Close all sessions except the currently focused one.
  ks -i            Interactive picker over active sessions; switch on select.
  ks -n            Interactive picker over KS_LOCATIONS subdirs; create on Enter.

Picker: KS_PICKER=fuzzel|dmenu|fzf (unset prefers fuzzel, then dmenu, then fzf).
fuzzel and dmenu are single-select; -k/-n multi-select needs fzf.
"""


def main(argv: list[str]) -> int:
    if not argv:
        sys.stderr.write(USAGE)
        return 1

    head = argv[0]
    rest = argv[1:]

    if head in ("-h", "--help"):
        sys.stdout.write(USAGE)
        return 0
    if head in ("-l", "--list"):
        cmd_list()
        return 0
    if head in ("-s", "--switch"):
        if not rest or not rest[0]:
            sys.stderr.write("ks: -s requires a session name\n")
            return 1
        cmd_switch(rest[0])
        return 0
    if head in ("-k", "--kill"):
        if not rest or not rest[0]:
            cmd_pick_kill()
        elif rest[0] in ("--all", "-a"):
            cmd_kill_all()
        else:
            cmd_kill(rest)
        return 0
    if head in ("-i", "--interactive"):
        cmd_pick_session()
        return 0
    if head in ("-n", "--new"):
        cmd_pick_new()
        return 0

    paths = [head, *rest]
    for p in paths:
        if not os.path.isdir(p):
            sys.stderr.write(f"ks: not a directory: {p}\n")
            return 1
    for p in paths:
        name = create_session(os.path.abspath(p))
        print(name)
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main(sys.argv[1:]))
    except KeyboardInterrupt:
        sys.exit(130)
