[Unit]
Description=NetworkManager system tray applet
PartOf=graphical-session.target
# After=waybar: register with the tray only once the StatusNotifierWatcher
# exists — registering into a mid-restart waybar loses the icon.
After=graphical-session.target waybar.service

[Service]
ExecStart=/usr/bin/nm-applet --indicator
Restart=on-failure
Slice=session.slice

[Install]
WantedBy=graphical-session.target
